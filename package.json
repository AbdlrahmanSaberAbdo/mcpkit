{
  "name": "mcpkit",
  "version": "0.1.0",
  "description": "MCP Developer Toolkit — scaffold, proxy, and inspect MCP servers",
  "type": "module",
  "bin": {
    "mcpkit": "dist/bin/mcpkit.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AbdlrahmanSaberAbdo/mcpkit.git"
  },
  "bugs": {
    "url": "https://github.com/AbdlrahmanSaberAbdo/mcpkit/issues"
  },
  "homepage": "https://github.com/AbdlrahmanSaberAbdo/mcpkit#readme",
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src bin",
    "lint:fix": "eslint src bin --fix",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai",
    "agent",
    "devtools"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "ws": "^8.18.0",
    "yaml": "^2.7.0",
    "@apidevtools/swagger-parser": "^10.1.1",
    "ejs": "^3.1.10",
    "open": "^10.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/ejs": "^3.1.5",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.14",
    "eslint": "^9.17.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.18.0",
    "vitest": "^3.0.0"
  }
}
